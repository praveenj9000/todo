{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,

    "allowJs": false,

    "noEmit": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "verbatimModuleSyntax": true
  }
}